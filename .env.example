# ============================================================
#  Лента.PM — Шаблон переменных окружения
#  Скопировать в .env и заполнить все значения
#  Файл .env НЕ передавать третьим лицам
# ============================================================

# ── ОБЯЗАТЕЛЬНЫЕ ────────────────────────────────────────────

# Секретный ключ для подписи сессий (минимум 32 символа)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замените-на-случайную-строку-минимум-32-символа

# Подключение к PostgreSQL
# Формат: postgresql://пользователь:пароль@хост:порт/база
DATABASE_URL=postgresql://lenta_user:пароль@localhost:5432/lenta_pm

# Телефон первого администратора (формат +7XXXXXXXXXX)
ADMIN_PHONE=+7XXXXXXXXXX

# Домен приложения (для Face ID / WebAuthn)
# В dev: localhost
# В prod: lenta-pm.ваш-домен.ru
APP_DOMAIN=localhost

# ── ИИ-АССИСТЕНТ (опционально) ──────────────────────────────

# Groq — бесплатно, получить на console.groq.com
GROQ_API_KEY=

# Claude (Anthropic) — платно, anthropic.com
ANTHROPIC_API_KEY=

# DeepSeek — дешевле Claude, platform.deepseek.com
DEEPSEEK_API_KEY=

# ── EMAIL-УВЕДОМЛЕНИЯ (опционально) ─────────────────────────

# Brevo SMTP — бесплатно 300 писем/день, app.brevo.com → Settings → SMTP & API
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=ваш-логин@smtp-brevo.com
SMTP_PASS=ваш-smtp-ключ
# Имя и адрес отправителя (должен быть верифицирован в Brevo)
SMTP_FROM=Лента.PM <ваш@email.com>

# ── ДАЙДЖЕСТ РУКОВОДИТЕЛЯ ───────────────────────────────────
# Ежедневное письмо в 09:00 МСК для Гаврина, Месмера, Митько
# Включить после запуска проекта: установить значение true
LEADER_DIGEST_ENABLED=false

# ── RAILWAY (заполняется автоматически при деплое) ───────────
# RAILWAY_ENVIRONMENT=production
